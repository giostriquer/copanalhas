{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Copanalhas Recap Copy Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "periodKey", "cards"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "periodKey": {
      "type": "string",
      "minLength": 1
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "title", "subtitle"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 34
          },
          "subtitle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 104
          }
        }
      }
    }
  }
}
